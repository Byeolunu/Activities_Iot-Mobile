<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFAF0"
    tools:context=".Multimedia">

    <TextView
        android:id="@+id/titleAnimaux"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="sans-serif-black"
        android:text="@string/activities_animals"
        android:textColor="#E91E63"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/titleUnderline"
        android:layout_width="100dp"
        android:layout_height="4dp"
        android:layout_marginTop="4dp"
        android:background="#E91E63"
        app:layout_constraintEnd_toEndOf="@+id/titleAnimaux"
        app:layout_constraintStart_toStartOf="@+id/titleAnimaux"
        app:layout_constraintTop_toBottomOf="@+id/titleAnimaux" />

    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/flow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:padding="16dp"
        app:constraint_referenced_ids="monkey,chien,chat,deer,elephant,koala"
        app:flow_horizontalGap="16dp"
        app:flow_horizontalStyle="packed"
        app:flow_maxElementsWrap="2"
        app:flow_verticalGap="16dp"
        app:flow_wrapMode="aligned"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titleUnderline" />

    <ImageView
        android:id="@+id/monkey"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="@drawable/image_border"
        android:padding="0dp"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        app:srcCompat="@drawable/monkey" />

    <ImageView
        android:id="@+id/chien"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="@drawable/image_border"
        android:padding="0dp"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        app:srcCompat="@drawable/chien" />

    <ImageView
        android:id="@+id/chat"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="@drawable/image_border"
        android:padding="0dp"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        app:srcCompat="@drawable/chat" />

    <ImageView
        android:id="@+id/deer"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="@drawable/image_border"
        android:padding="0dp"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        app:srcCompat="@drawable/deer" />

    <ImageView
        android:id="@+id/elephant"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="@drawable/image_border"
        android:padding="0dp"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        app:srcCompat="@drawable/elephant" />

    <ImageView
        android:id="@+id/koala"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="@drawable/image_border"
        android:padding="0dp"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        app:srcCompat="@drawable/koala" />

    <Button
        android:id="@+id/chiffres"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="#E91E63"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="Chiffres"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/flow" />

</androidx.constraintlayout.widget.ConstraintLayout>